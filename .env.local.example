NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# App base URL (e.g. https://sorene.ai in production, http://localhost:3000 locally)
NEXT_PUBLIC_APP_URL=
# Google OAuth Web Client ID (for Google Identity Services sign-in)
# Find it in: Firebase Console → Authentication → Sign-in method → Google → Web client ID
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

ANTHROPIC_API_KEY=

# Firebase Admin SDK (for API route auth verification)
# JSON string of your Firebase service account key
FIREBASE_SERVICE_ACCOUNT_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe webhook signing secret — https://dashboard.stripe.com/webhooks
# Set the endpoint URL to: https://sorene.ai/api/subscription/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — https://dashboard.stripe.com/products
# Create 4 prices (recurring): Starter monthly, Starter 6-month, Pro monthly, Pro 6-month
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_SEMI_ANNUAL=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_SEMI_ANNUAL=price_...

# Threads (Meta) OAuth — https://developers.facebook.com/apps/1548705940208943
THREADS_APP_ID=
THREADS_APP_SECRET=
# Must match the redirect URI registered in your Meta app
# e.g. https://sorene.ai/api/social/threads/callback
THREADS_REDIRECT_URI=
